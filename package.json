{
  "name": "clawchat",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @clawchat/shared build && pnpm --filter @clawchat/server --filter @clawchat/client build",
    "invite": "pnpm --filter @clawchat/server invite",
    "generate-vapid": "npx web-push generate-vapid-keys"
  },
  "workspaces": ["server", "client", "shared", "widget-server"],
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
